{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/templates/**", "backend/static/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}
