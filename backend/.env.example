# Flask
SECRET_KEY=change-me-to-a-random-string
PORT=5000
LOG_LEVEL=INFO

# PageSpeed Insights API (for Optimizer tool)
# Get free key: console.cloud.google.com → Enable PageSpeed Insights API → Credentials → API Key
PAGESPEED_API_KEY=

# Gmail (for emailing optimizer reports — optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Web Team

# Gemini AI (for Page Cloner — optional, falls back to template mode)
GEMINI_API_KEY=

# Resend (for Audit Wizard email reports — optional)
RESEND_API_KEY=
